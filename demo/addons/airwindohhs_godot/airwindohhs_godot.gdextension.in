[configuration]

entry_symbol = "airwindohhs_godot_library_init"
compatibility_minimum = "4.6"
reloadable = true

[libraries]

macos.debug = "res://addons/airwindohhs_godot/bin/libairwindohhs_godot.macos.template_debug.dylib"
macos.release = "res://addons/airwindohhs_godot/bin/libairwindohhs_godot.macos.template_release.dylib"
linux.debug.x86_64 = "res://addons/airwindohhs_godot/bin/libairwindohhs_godot.linux.template_debug.so"
linux.release.x86_64 = "res://addons/airwindohhs_godot/bin/libairwindohhs_godot.linux.template_release.so"
windows.debug.x86_64 = "res://addons/airwindohhs_godot/bin/airwindohhs_godot.windows.template_debug.dll"
windows.release.x86_64 = "res://addons/airwindohhs_godot/bin/airwindohhs_godot.windows.template_release.dll"
